# Python venv
venv/
.venv/

# Project-local model cache (~1 GB+ per model — ship via USB, not git)
# Track the folder via its README.md, but ignore everything else.
models/*
!models/README.md

# Modelscope cache (if symlinked or copied here)
.cache/

# Offline Python dependency bundle for USB installs (large, platform-specific)
wheelhouse/
.wheelhouse-venv/

# Runtime output
log_data/
output/
logs/
*.csv

# Node dependencies for the central receiver
receiver/node_modules/

# Python bytecode
__pycache__/
*.pyc

# OS junk
.DS_Store
